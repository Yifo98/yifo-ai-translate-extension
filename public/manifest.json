{
  "manifest_version": 3,
  "name": "Yifo AI Translate",
  "short_name": "Yifo",
  "version": "0.1.0",
  "description": "准确优先的沉浸式网页翻译扩展，支持 GLM、DeepSeek 与 OpenAI-compatible 接口。",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["storage", "scripting", "contextMenus", "activeTab", "tabs"],
  "host_permissions": [
    "https://api.deepseek.com/*",
    "https://open.bigmodel.cn/*",
    "https://*/*",
    "http://*/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "icons/launcher.svg",
        "icons/yiflow.svg",
        "icons/icon-16.png",
        "icons/icon-32.png",
        "icons/icon-48.png",
        "icons/icon-128.png"
      ],
      "matches": ["https://*/*", "http://*/*"]
    }
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Yifo AI Translate",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_popup": "popup.html"
  },
  "options_page": "options.html"
}
